<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NeuralNetworkApp.ViewModels"
        x:Class="NeuralNetworkApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Sztuczna Sieć Neuronowa - Dashboard" Width="950" Height="650"
        Background="#F5F7FA">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="320, *">
        <Border Grid.Column="0" Background="#1E293B" Padding="20">
            <ScrollViewer>
                <StackPanel Spacing="15">
                    <TextBlock Text="PARAMETRY SIECI" FontSize="16" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                    <TextBlock Text="Liczba wejść:" Foreground="#94A3B8" FontSize="12"/>
                    <TextBox Text="{Binding InputCount}" Background="#334155" Foreground="White" BorderThickness="0"/>

                    <TextBlock Text="Liczba wyjść:" Foreground="#94A3B8" FontSize="12"/>
                    <TextBox Text="{Binding OutputCount}" Background="#334155" Foreground="White" BorderThickness="0"/>

                    <TextBlock Text="Współczynnik uczenia (η):" Foreground="#94A3B8" FontSize="12"/>
                    <TextBox Text="{Binding LearningRate}" Background="#334155" Foreground="White" BorderThickness="0"/>

                    <TextBlock Text="Maksymalna ilość epok:" Foreground="#94A3B8" FontSize="12"/>
                    <TextBox Text="{Binding MaxEpochs}" Background="#334155" Foreground="White" BorderThickness="0"/>

                    <TextBlock Text="Maksymalny błąd (MSE):" Foreground="#94A3B8" FontSize="12"/>
                    <TextBox Text="{Binding MaxError}" Background="#334155" Foreground="White" BorderThickness="0"/>

                    <TextBlock Text="Warstwy ukryte (np. 4,4):" Foreground="#94A3B8" FontSize="12"/>
                    <TextBox Text="{Binding HiddenLayersConfig}" Background="#334155" Foreground="White" BorderThickness="0"/>

                    <TextBlock Text="Funkcja aktywacji:" Foreground="#94A3B8" FontSize="12"/>
                    <ComboBox SelectedIndex="{Binding SelectedActivationIndex}" HorizontalAlignment="Stretch" Background="#334155" Foreground="White">
                        <ComboBoxItem Content="Unipolarna"/>
                        <ComboBoxItem Content="Bipolarna"/>
                    </ComboBox>

                    <TextBlock Text="Ścieżka do pliku (*.tab):" Foreground="#94A3B8" FontSize="12"/>
                    <TextBox Text="{Binding FilePath}" Background="#334155" Foreground="White" BorderThickness="0"/>

                    <Border Height="1" Background="#334155" Margin="0,10"/>

                    <Button Content="Uruchom uczenie" Command="{Binding StartTrainingAsync}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#2563EB" Foreground="White" Height="35" FontWeight="SemiBold"/>
                    
                    <Grid ColumnDefinitions="*, *">
                        <Button Grid.Column="0" Content="Krok (1 epoka)" Command="{Binding TrainSingleStepAsync}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#059669" Foreground="White" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Zapisz sieć" Command="{Binding SaveNetworkWeightsAsync}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#475569" Foreground="White" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto, 220, *, Auto" Margin="20">
            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BoxShadow="0 4 6 -1 rgba(0,0,0,0.05)">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Status systemu" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Status}" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentEpochDisplay}" FontSize="16" FontWeight="Bold" Foreground="#2563EB"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BoxShadow="0 4 6 -1 rgba(0,0,0,0.05)">
                <DockPanel>
                    <TextBlock Text="Wizualizacja błędu (Wykres MSE)" DockPanel.Dock="Top" FontSize="13" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                    <Grid>
                        <Canvas Background="#F8FAFC" Width="600" Height="160" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Polyline Points="{Binding ChartPoints}" Stroke="#EF4444" StrokeThickness="2.5"/>
                        </Canvas>
                        <TextBlock Text="{Binding MaxError}" VerticalAlignment="Bottom" Margin="5" FontSize="10" Foreground="#94A3B8"/>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" BoxShadow="0 4 6 -1 rgba(0,0,0,0.05)">
                <DockPanel>
                    <TextBlock Text="Dane pośrednie algorytmu (Logi)" DockPanel.Dock="Top" FontSize="13" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding LogEntries}" Background="Transparent" BorderThickness="0" FontSize="12" FontFamily="Consolas">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#334155"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" BoxShadow="0 4 6 -1 rgba(0,0,0,0.05)">
    <Grid ColumnDefinitions="*, *">
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Dane pośrednie algorytmu (Logi)" DockPanel.Dock="Top" FontSize="13" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
            <ListBox ItemsSource="{Binding LogEntries}" Background="Transparent" BorderThickness="0" FontSize="12" FontFamily="Consolas">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#334155"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
        
        <DockPanel Grid.Column="1" Margin="10,0,0,0">
            <TextBlock Text="Modyfikacja danych wejściowych (Format .tab)" DockPanel.Dock="Top" FontSize="13" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
            <TextBox Text="{Binding LoadedDataContent}" 
                AcceptsReturn="True" 
                Background="#F8FAFC" 
                Foreground="#1E293B"
                BorderBrush="#E2E8F0" 
                FontSize="12" 
                FontFamily="Consolas" 
                VerticalAlignment="Stretch" 
                HorizontalAlignment="Stretch">
                <TextBox.Styles>
                    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                    </Style>
                    <Style Selector="TextBox:pointerover">
                        <Setter Property="Foreground" Value="#1E293B"/>
                    </Style>
                    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="BorderBrush" Value="#2563EB"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                    <Style Selector="TextBox:focus">
                        <Setter Property="Foreground" Value="#0F172A"/>
                    </Style>
                </TextBox.Styles>
            </TextBox>
        </DockPanel>
    </Grid>
</Border>
            
            <TextBlock Grid.Row="3" Text="Sztuczna Sieć Neuronowa | Projekt Zaliczeniowy" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </Grid>
    </Grid>
</Window>